<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Crypto Stars</title>

<!-- Гарний шрифт -->
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  height: 100vh;
  background: radial-gradient(circle at center, #0a0a12, #000);
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: 'Orbitron', sans-serif;
}

/* Контейнер */
.logo {
  display: flex;
  align-items: center;
  gap: 20px;
  font-size: 50px;
  color: #00f7ff;
}

/* Текст */
.text {
  opacity: 0;
  transform: translateY(30px);
  animation: fadeUp 1.5s ease forwards;
}

/* Зірка */
.star {
  font-size: 60px;
  color: gold;
  opacity: 0;
  transform: scale(0.5);
  animation: starPop 1.5s ease forwards;
  animation-delay: 0.5s;
  text-shadow: 0 0 20px gold, 0 0 40px orange;
}

/* Затримки */
.text.left {
  animation-delay: 0s;
}

.text.right {
  animation-delay: 1s;
}

/* Анімації */
@keyframes fadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes starPop {
  0% {
    opacity: 0;
    transform: scale(0.2);
  }
  60% {
    transform: scale(1.3);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}
</style>
</head>

<body>

<div class="logo">
  <div class="text left">CRYPTO</div>
  <div class="star">⭐</div>
  <div class="text right">STARS</div>
</div>

</body>
</html>
